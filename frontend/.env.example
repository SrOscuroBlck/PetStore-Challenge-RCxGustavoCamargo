# Frontend environment — copy to `.env` and adjust. `.env` is git-ignored; never commit it.
#
# This app holds NO secrets and no credential. In prod it is served same-origin behind the
# nginx gateway, which injects the customer Authorization header on /graphql (ADR-0005), so
# the browser never sees a credential. The vars below only configure the DEV server.

# --- Dev server proxy (vite.config.ts) ---
# Backend TLS endpoint that `npm run dev` proxies /graphql and /pictures to.
VITE_DEV_API_PROXY_TARGET=https://localhost:8443

# Dev parity with the prod gateway: the Vite proxy injects this customer credential as HTTP
# Basic on /graphql, so the browser never holds it. These are read server-side by vite.config
# and are deliberately NOT prefixed VITE_ (a VITE_ var would be inlined into the client bundle).
# The demo customer is published in the challenge docs.
DEV_CUSTOMER_EMAIL=customer@petstore.local
DEV_CUSTOMER_PASSWORD=demo-password

# Optional: store id to send a bare "/" to in dev (skip hand-typing the route).
# Get the demo store id from the cluster (see docs/BACKEND_INTEGRATION.md §3).
VITE_DEFAULT_STORE_ID=
