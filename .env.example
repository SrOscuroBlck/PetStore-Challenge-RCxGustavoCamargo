# HTTP listen address (required, no default).
HTTP_ADDR=:8443

# Log level: debug | info | warn | error (optional, default: info).
LOG_LEVEL=info

# PostgreSQL connection. Used by Atlas migrations and the Go app from the
# persistence layer onward. Matches the local docker-compose Postgres.
DATABASE_URL=postgres://petstore:petstore@localhost:5434/petstore?sslmode=disable

# Key for app-layer PII encryption (AES-256-GCM) and the email blind index
# (HMAC-SHA-256). Required, no default. Must be a base64-encoded 32-byte value.
# Generate one with: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# TLS (required — the server only accepts HTTPS). Generate local dev certs with
# `make tls-certs`, which writes ./certs/cert.pem and ./certs/key.pem.
TLS_CERT_FILE=./certs/cert.pem
TLS_KEY_FILE=./certs/key.pem

# Enable GraphQL schema introspection (optional, default false). Turn on only in
# development; it is disabled in production to reduce the attack surface.
GRAPHQL_INTROSPECTION=false

# Redis cache for the available-pets catalog (required). Cache-aside accelerator:
# reads still succeed from Postgres if Redis is unavailable. Matches the local
# docker-compose Redis (host port 6380 -> container 6379).
REDIS_ADDR=localhost:6380

# MinIO object storage for pet pictures (required). Matches the local
# docker-compose MinIO service. Endpoint is host:port WITHOUT a scheme.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pet-pictures
# Reach MinIO over TLS (optional, default: false for local http).
MINIO_USE_SSL=false
