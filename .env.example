# HTTP listen address (required, no default).
HTTP_ADDR=:8443

# Log level: debug | info | warn | error (optional, default: info).
LOG_LEVEL=info

# PostgreSQL connection. Used by Atlas migrations now; the Go app reads it from the
# persistence layer onward. Matches the local docker-compose Postgres.
DATABASE_URL=postgres://petstore:petstore@localhost:5434/petstore?sslmode=disable
