# HTTP listen address (required, no default).
HTTP_ADDR=:8443

# Log level: debug | info | warn | error (optional, default: info).
LOG_LEVEL=info

# PostgreSQL connection. Used by Atlas migrations and the Go app from the
# persistence layer onward. Matches the local docker-compose Postgres.
DATABASE_URL=postgres://petstore:petstore@localhost:5434/petstore?sslmode=disable

# Key for app-layer PII encryption (AES-256-GCM) and the email blind index
# (HMAC-SHA-256). Required, no default. Must be a base64-encoded 32-byte value.
# Generate one with: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# TLS termination (TLS_CERT_FILE / TLS_KEY_FILE) is added in issue #7 / the
# Minikube ingress; until then Basic-auth runs over plaintext HTTP locally.
